# ── Backend secrets — copy this file to .env and fill in values ──

# Required: model provider
OPENROUTER_API_KEY=

# Required: Supabase project (Settings → API)
SUPABASE_URL=https://<project-ref>.supabase.co

# Required: Supabase Postgres pooler URL (Settings → Database → Connection pooling)
# Format: postgresql://postgres.<ref>:<password>@aws-...pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=

# Optional: LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=FYP

# Optional: only if you swap to OpenAI directly instead of OpenRouter
OPENAI_API_KEY=
