# ── Backend secrets — copy this file to .env and fill in values ──

# Required: model provider
OPENROUTER_API_KEY=

# Default model used when the UI doesn't send one (and for the first agent
# built at startup). Pick from `curl /v1/models` or the model picker.
# Examples:
#   inclusionai/ring-2.6-1t:free     reasoning, routes via Novita
#   openai/gpt-oss-120b:free         general-purpose
#   meta-llama/llama-3.3-70b-instruct:free   default, routes via Venice (often throttled)
CHAT_MODEL=inclusionai/ring-2.6-1t:free

# Optional: cap completion tokens. Leave blank to let each upstream
# decide — reasoning models need this room.
CHAT_MAX_TOKENS=

# Required: Supabase project (still used for Auth / JWT verification)
SUPABASE_URL=https://<project-ref>.supabase.co

# Required: Postgres connection string.
#   Local docker-compose default:
#     postgresql://postgres:postgres@localhost:5432/acm
#   Supabase pooler:
#     postgresql://postgres.<ref>:<password>@aws-...pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:5432/acm

# ── Object storage (S3-compatible) ───────────────────────────────────────────
# Local MinIO defaults match docker-compose.yml. Point S3_ENDPOINT_URL at
# https://s3.amazonaws.com (or leave blank) and supply real keys for AWS S3.
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET=project-files

# ── Sandboxed workspaces (Phase 1) ───────────────────────────────────────────
# SANDBOX_BACKEND selects which sandbox implementation to use.
#   docker — local Docker socket. Fast, free, UNSAFE for multi-user (a
#            container escape = host root). Solo-dev / localhost only.
#   e2b    — E2B managed Firecracker microVMs (e2b.dev). Safe for multi-user.
#            Requires E2B_API_KEY from https://e2b.dev/dashboard.
# Flip to e2b before letting anyone else hit this app — see PROJECT.md.
SANDBOX_BACKEND=docker
E2B_API_KEY=

# Workspace lifecycle.
WORKSPACE_TTL_HOURS=24          # destroyed this long after last_used_at
WORKSPACE_IDLE_PAUSE_MIN=15     # paused (compute freed) after this idle gap
WORKSPACE_MAX_PER_USER=3        # concurrent active workspaces per user
WORKSPACE_IMAGE=acm-workspace:latest  # used by the docker backend only

# Optional: LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=FYP

# Optional: only if you swap to OpenAI directly instead of OpenRouter
OPENAI_API_KEY=
