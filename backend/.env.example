# ── Backend secrets — copy this file to .env and fill in values ──

# Required: model provider
OPENROUTER_API_KEY=

# Default model used when the UI doesn't send one (and for the first agent
# built at startup). Pick from `curl /v1/models` or the model picker.
# Primary models for chat / demo / projects:
#   google/gemini-3.1-flash-lite     default — fast, cheap, large context
#   minimax/minimax-m3               large-context reasoning
#   stepfun/step-3.7-flash           fast general-purpose
# Leave unset to use the code default (google/gemini-3.1-flash-lite).
CHAT_MODEL=google/gemini-3.1-flash-lite

# Optional: cap completion tokens. Leave blank to let each upstream
# decide — reasoning models need this room.
CHAT_MAX_TOKENS=

# Required: Keycloak local auth service (replaces Supabase Auth)
# Keycloak runs as a docker-compose service on port 8080 by default.
# Realm 'acm' and client 'acm-frontend' are auto-provisioned from
# keycloak/realm-export.json on first start.
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=acm

# Required: Postgres connection string.
#   Local docker-compose default (matches docker-compose.yml):
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:5432/acm

# ── Object storage (S3-compatible) ───────────────────────────────────────────
# Local MinIO defaults match docker-compose.yml. Point S3_ENDPOINT_URL at
# https://s3.amazonaws.com (or leave blank) and supply real keys for AWS S3.
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET=project-files

# ── Sandboxed workspaces (Phase 1) ───────────────────────────────────────────
# SANDBOX_BACKEND selects which sandbox implementation to use.
#   docker — local Docker socket. Fast, free, UNSAFE for multi-user (a
#            container escape = host root). Solo-dev / localhost only.
#   e2b    — E2B managed Firecracker microVMs (e2b.dev). Safe for multi-user.
#            Requires E2B_API_KEY from https://e2b.dev/dashboard.
# Flip to e2b before letting anyone else hit this app — see PROJECT.md.
SANDBOX_BACKEND=docker
E2B_API_KEY=

# Workspace lifecycle.
WORKSPACE_TTL_HOURS=24          # destroyed this long after last_used_at
WORKSPACE_IDLE_PAUSE_MIN=15     # paused (compute freed) after this idle gap
WORKSPACE_MAX_PER_USER=3        # concurrent active workspaces per user
WORKSPACE_IMAGE=acm-workspace:latest  # used by the docker backend only

# ── Context-management strategy ──────────────────────────────────────────────
# How the agent's tool surface is presented to the LLM each turn.
#   tool_calling   (default) — classic ReAct: every tool is its own
#                              LangChain tool, agent calls one per round.
#   ts_code_mode             — catalog + describe_tools + execute_typescript.
#                              The agent picks tool names from a compact
#                              catalog, fetches full TS interfaces on demand,
#                              and runs one TS program per turn in a Deno
#                              isolate. Requires `deno` on the host (see below).
# Per-request override is available via ChatRequest.context_strategy.
DEFAULT_CONTEXT_STRATEGY=tool_calling

# Path to the Deno binary used by ts_code_mode. Override if Deno lives
# somewhere outside PATH (e.g. unusual CI image). Only resolved when a
# ts_code_mode turn fires, so leaving this unset is fine if you don't
# use ts_code_mode.
DENO_BIN=deno

# ── MCP inventory ────────────────────────────────────────────────────────────
# Secrets users save in `mcp_servers.secret_blob` are encrypted with Fernet.
# Set this once, keep it stable — losing the key invalidates every saved
# token / env-var value. `python -c "from cryptography.fernet import Fernet;
# print(Fernet.generate_key().decode())"` to generate one.
MCP_SECRET_KEY=
# Set to 1 to permit http://localhost endpoints in custom MCP entries (dev only).
MCP_ALLOW_LOCAL_HTTP=0
# Hard cap on saved MCPs per user. Bump if needed.
MCP_MAX_PER_USER=20

# Optional: LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=FYP

# Optional: only if you swap to OpenAI directly instead of OpenRouter
OPENAI_API_KEY=
