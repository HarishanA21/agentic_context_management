{
  "name": "acm-context-management",
  "displayName": "Context Management - ACM",
  "description": "Agentic Context Management for VSCode — trim, summarise, recall, and remember context for Copilot and Claude Code via a local gateway, Language Model Tools, and a settings panel.",
  "version": "0.2.5",
  "publisher": "Harishan-A",
  "license": "MIT",
  "icon": "media/icon.png",
  "qna": "marketplace",
  "keywords": [
    "context management",
    "ai",
    "copilot",
    "claude",
    "llm",
    "memory",
    "tokens",
    "mcp"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/badge/license-MIT-green.svg",
      "href": "https://github.com/HarishanA21/agentic_context_management/blob/main/LICENSE",
      "description": "MIT License"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/HarishanA21/agentic_context_management.git",
    "directory": "extension/adapters/vscode"
  },
  "homepage": "https://github.com/HarishanA21/agentic_context_management",
  "bugs": {
    "url": "https://github.com/HarishanA21/agentic_context_management/issues"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "acm.openSettings",
        "title": "ACM: Open Context-Management Settings"
      },
      {
        "command": "acm.showContextWindow",
        "title": "ACM: Show Context Window"
      },
      {
        "command": "acm.showStatus",
        "title": "ACM: Show Gateway Status"
      },
      {
        "command": "acm.recall",
        "title": "ACM: Recall Memory"
      },
      {
        "command": "acm.enableMonitoring",
        "title": "ACM: Monitor Claude Code (route through gateway)"
      },
      {
        "command": "acm.disableMonitoring",
        "title": "ACM: Stop Monitoring Claude Code (restore routing)"
      },
      {
        "command": "acm.restartGateway",
        "title": "ACM: Restart Gateway"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "acm",
          "title": "ACM",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "acm": [
        {
          "id": "acm.sidebar",
          "name": "Context Management",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "ACM Context Management",
      "properties": {
        "acm.gatewayUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8807",
          "description": "Base URL of the local acm-gateway."
        },
        "acm.memoryScope": {
          "type": "string",
          "default": "user",
          "enum": [
            "user",
            "thread"
          ],
          "description": "Default scope for ACM memory tools."
        },
        "acm.manageGateway": {
          "type": "boolean",
          "default": true,
          "description": "Start and supervise the acm-gateway process automatically (restart on crash, stop on shutdown). If a gateway is already running on the URL, it is adopted instead of spawning a duplicate."
        },
        "acm.gatewayCommand": {
          "type": "string",
          "default": "acm-gateway",
          "description": "Command used to launch the gateway when acm.manageGateway is on. Must be on PATH (e.g. after `uv tool install acm-context-management`) or an absolute path / full command (e.g. `python -m acm_gateway`)."
        },
        "acm.routeClaudeCode": {
          "type": "boolean",
          "default": true,
          "description": "Point Claude Code at the gateway by managing env.ANTHROPIC_BASE_URL in your Claude Code settings. Written only once the gateway is healthy and removed on shutdown, so Claude Code is never left pointing at a dead gateway. On a Claude subscription this needs no API key — your own OAuth token is forwarded and monitored."
        },
        "acm.routeScope": {
          "type": "string",
          "default": "user",
          "enum": [
            "user",
            "project"
          ],
          "enumDescriptions": [
            "Write ANTHROPIC_BASE_URL to ~/.claude/settings.json — applies to every Claude Code session on this machine (recommended; the gateway URL is machine-local).",
            "Advanced: write to this workspace's .claude/settings.local.json — scoped to this project and not committed to git."
          ],
          "description": "Where to manage ANTHROPIC_BASE_URL for Claude Code routing."
        }
      }
    },
    "chatParticipants": [
      {
        "id": "acm.agent",
        "name": "acm",
        "fullName": "ACM",
        "description": "Context-management helper — status, recall, compaction.",
        "isSticky": true
      }
    ],
    "languageModelTools": [
      {
        "name": "acm_remember",
        "displayName": "ACM: Remember",
        "modelDescription": "Persist a fact to local ACM memory so future turns/sessions can recall it. Use for decisions, file paths, open tasks worth carrying forward.",
        "toolReferenceName": "acmRemember",
        "canBeReferencedInPrompt": true,
        "icon": "$(save)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "description": "The fact to remember."
            },
            "scope": {
              "type": "string",
              "enum": [
                "user",
                "thread"
              ],
              "description": "Memory scope."
            }
          },
          "required": [
            "text"
          ]
        }
      },
      {
        "name": "acm_recall",
        "displayName": "ACM: Recall",
        "modelDescription": "Recall facts previously stored in ACM memory, optionally filtered by a query.",
        "toolReferenceName": "acmRecall",
        "canBeReferencedInPrompt": true,
        "icon": "$(book)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Optional substring filter."
            },
            "scope": {
              "type": "string",
              "enum": [
                "user",
                "thread"
              ]
            }
          }
        }
      },
      {
        "name": "acm_compact",
        "displayName": "ACM: Compact",
        "modelDescription": "Summarise a long transcript into a short carry-over note using the ACM summariser via the gateway.",
        "toolReferenceName": "acmCompact",
        "canBeReferencedInPrompt": true,
        "icon": "$(fold)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "description": "The transcript to compact."
            }
          },
          "required": [
            "text"
          ]
        }
      },
      {
        "name": "acm_set_profile",
        "displayName": "ACM: Set Profile",
        "modelDescription": "Switch the active context-management preset (minimal, long_chat, power_research, cheap_long, visual_recall).",
        "toolReferenceName": "acmSetProfile",
        "canBeReferencedInPrompt": true,
        "icon": "$(settings-gear)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Preset name."
            }
          },
          "required": [
            "name"
          ]
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "build:host": "tsc -p ./",
    "build:ui": "node esbuild.mjs",
    "typecheck:ui": "tsc -p tsconfig.ui.json",
    "compile": "npm run build:host && npm run build:ui",
    "watch": "tsc -watch -p ./",
    "watch:ui": "node esbuild.mjs --watch",
    "package": "vsce package --no-dependencies",
    "publish:vsce": "vsce publish --no-dependencies",
    "publish:ovsx": "ovsx publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/vscode": "^1.95.0",
    "esbuild": "^0.23.0",
    "react": "^18",
    "react-dom": "^18",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "react-markdown": "^9.1.0"
  }
}
