# Keycloak local auth service (replaces Supabase Auth)
# Matches the keycloak service in docker-compose.yml
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=acm
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=acm-frontend

# Keycloak admin credentials (used only for user registration via Admin REST API)
# Change these in production!
NEXT_PUBLIC_KEYCLOAK_ADMIN=admin
NEXT_PUBLIC_KEYCLOAK_ADMIN_PASSWORD=admin
